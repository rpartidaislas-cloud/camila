function toggleCalc(open) {
  document.getElementById('calculator').classList.toggle('hidden', !open);
  document.getElementById('calcFab').classList.toggle('hidden', open);
  if (!open) {
    state.calcExpr = "";
    document.getElementById('calcDisplay').textContent = "0";
  }
}
function calcAppend(t) {
  state.calcExpr += t;
  document.getElementById('calcDisplay').textContent = state.calcExpr || "0";
}
function calcDel() {
  state.calcExpr = state.calcExpr.slice(0, -1);
  document.getElementById('calcDisplay').textContent = state.calcExpr || "0";
}
function calcClear() {
  state.calcExpr = "";
  document.getElementById('calcDisplay').textContent = "0";
}
function calcEval() {
  if (!state.calcExpr) return;
  // Whitelist only digits, ops, parens, dot, **, and space
  if (!/^[0-9+\-*/().\s*]+$/.test(state.calcExpr)) {
    document.getElementById('calcDisplay').textContent = "Error";
    return;
  }
  try {
    // eslint-disable-next-line no-new-func
    const res = Function('"use strict"; return (' + state.calcExpr + ')')();
    if (typeof res !== 'number' || !isFinite(res)) throw new Error("inv");
    state.calcExpr = String(Number(res.toFixed(8)));
    document.getElementById('calcDisplay').textContent = state.calcExpr;
  } catch (e) {
    document.getElementById('calcDisplay').textContent = "Error";
  }
}

/* Drag the calculator */
(function makeDraggable() {
  let dragging = false, offX = 0, offY = 0;
  const calc = document.getElementById('calculator');
  const header = document.getElementById('calcHeader');
  header.addEventListener('mousedown', (e) => {
    dragging = true;
    const r = calc.getBoundingClientRect();
    offX = e.clientX - r.left; offY = e.clientY - r.top;
    document.body.style.userSelect = 'none';
  });
  window.addEventListener('mouseup', () => { dragging = false; document.body.style.userSelect = ''; });
  window.addEventListener('mousemove', (e) => {
    if (!dragging) return;
    calc.style.left = (e.clientX - offX) + 'px';
    calc.style.top = (e.clientY - offY) + 'px';
    calc.style.right = 'auto';
    calc.style.bottom = 'auto';
  });
})();

/* =========================================================================
   SPREADSHEET ENGINE  (mini Excel) — UNA HOJA POR PREGUNTA
   ========================================================================= */
const SHEET = {
  rows: 20,
  cols: 8,        // A..H
  cells: {},      // { 'A1': { raw: '5', val: 5 } }  (de la pregunta activa)
  selected: 'A1',
  activeQid: null, // pregunta a la que pertenece la hoja actualmente abierta
  storeKey: () => 'exam_sheets_' + (state.session ? state.session.student : 'anon'),
  visibleQTypes: ['calc', 'open']
};

function colName(i) { return String.fromCharCode(65 + i); }

function findQuestion(qid) {
  for (const sec of state.bank.sections) {
    const q = sec.questions.find(qq => qq.id === qid);
    if (q) return { q, sec };
  }
  return null;
}

function getActiveCalcQid() {
  if (!state.session) return null;
  const sec = state.bank.sections[state.session.currentSection];
  const q = sec.questions.find(q => SHEET.visibleQTypes.includes(q.type));
  return q ? q.id : null;
}

function sheetLoadForQuestion(qid) {
  const all = loadStore(SHEET.storeKey(), {});
  const data = all[qid] || { cells: {}, selected: 'A1' };
  SHEET.cells = data.cells || {};
  SHEET.selected = data.selected || 'A1';
  SHEET.activeQid = qid;
}

function sheetSave() {
  if (!SHEET.activeQid) return;
  const all = loadStore(SHEET.storeKey(), {});
  all[SHEET.activeQid] = { cells: SHEET.cells, selected: SHEET.selected };
  saveStore(SHEET.storeKey(), all);
}

function sheetCountCells(qid) {
  const all = loadStore(SHEET.storeKey(), {});
  const data = all[qid];
  if (!data || !data.cells) return 0;
  return Object.keys(data.cells).filter(a => data.cells[a] && data.cells[a].raw !== '' && data.cells[a].raw != null).length;
}

/* Build grid once */
function sheetBuild() {
  const tbl = document.getElementById('sheetTable');
  let html = '<thead><tr><th class="corner"></th>';
  for (let c = 0; c < SHEET.cols; c++) html += `<th>${colName(c)}</th>`;
  html += '</tr></thead><tbody>';
  for (let r = 1; r <= SHEET.rows; r++) {
    html += `<tr><th>${r}</th>`;
    for (let c = 0; c < SHEET.cols; c++) {
      const addr = colName(c) + r;
      html += `<td><div class="sheet-cell" id="cell-${addr}" data-addr="${addr}" tabindex="0" contenteditable="false"></div></td>`;
    }
    html += '</tr>';
  }
  html += '</tbody>';
  tbl.innerHTML = html;

  // Attach listeners (sólo mouse; el teclado se maneja de forma global más abajo)
  tbl.querySelectorAll('.sheet-cell').forEach(div => {
    div.addEventListener('mousedown', (e) => sheetCellMouseDown(div.dataset.addr, e));
    div.addEventListener('mouseenter', () => sheetCellMouseEnter(div.dataset.addr));
    div.addEventListener('dblclick', () => sheetEditCell(div.dataset.addr));
    // Sincronizar lo que el alumno teclea en la celda con la barra de fórmulas
    div.addEventListener('input', () => {
      if (div.classList.contains('editing')) {
        document.getElementById('sheetFormulaBar').value = div.textContent;
      }
    });
  });

  // Listener GLOBAL de teclado: maneja flechas, Delete, Ctrl+Z, Ctrl+Y, etc.
  // Esto resuelve el problema de que las flechas sólo funcionaban si la celda tenía foco.
  if (!window._sheetKeyHandlerInstalled) {
    window.addEventListener('keydown', sheetGlobalKeyHandler);
    window._sheetKeyHandlerInstalled = true;
  }

  // Global mouseup ends any drag
  if (!window._sheetMouseUpInstalled) {
    window.addEventListener('mouseup', sheetGlobalMouseUp);
    window._sheetMouseUpInstalled = true;
  }
  // Reposicionar fill handle al hacer scroll dentro del grid
  const wrap = document.querySelector('.sheet-grid-wrap');
  if (wrap && !wrap._scrollHooked) {
    wrap.addEventListener('scroll', positionFillHandle);
    wrap._scrollHooked = true;
  }

  // Formula bar listeners
  const fb = document.getElementById('sheetFormulaBar');
  fb.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      e.preventDefault();
      // Asegurar que cualquier celda en edición termine antes
      sheetCommitEditingCell();
      sheetSet(SHEET.selected, fb.value);
      sheetMove(0, 1);
    } else if (e.key === 'Escape') {
      fb.value = (SHEET.cells[SHEET.selected] || {}).raw || '';
      sheetRender();
      document.getElementById('cell-' + SHEET.selected).focus();
    }
  });
  // Si el usuario hace blur de la barra (click fuera), también hacer commit
  fb.addEventListener('blur', () => {
    const currentRaw = (SHEET.cells[SHEET.selected] || {}).raw || '';
    if (fb.value !== currentRaw) {
      sheetSet(SHEET.selected, fb.value);
    }
  });
}

/* =========================================================================
   GLOBAL KEYBOARD HANDLER de la hoja
   Funciona aún cuando ninguna celda específica tenga focus.
   Sólo actúa cuando el modal de la hoja está abierto.
   ========================================================================= */
function sheetGlobalKeyHandler(e) {
  // Sólo si la hoja está visible
  const modal = document.getElementById('sheetModal');
  if (!modal || modal.classList.contains('hidden')) return;

  // Si el foco está en un input/textarea/contentEditable activo (formula bar o celda editando), no interceptar
  const ae = document.activeElement;
  if (ae) {
    const tag = (ae.tagName || '').toLowerCase();
    const isCellEditing = ae.classList && ae.classList.contains('editing');
    const isFormulaBar = ae.id === 'sheetFormulaBar';
    if (isCellEditing) return;
    if (isFormulaBar && !['Escape'].includes(e.key)) return;
    if ((tag === 'input' || tag === 'textarea') && !isFormulaBar) return;
  }

  const k = e.key;
  // Ctrl/Cmd + Z: undo
  if ((e.ctrlKey || e.metaKey) && !e.shiftKey && k.toLowerCase() === 'z') {
    e.preventDefault(); sheetUndo(); return;
  }
  // Ctrl/Cmd + Y o Ctrl+Shift+Z: redo
  if (((e.ctrlKey || e.metaKey) && k.toLowerCase() === 'y') ||
      ((e.ctrlKey || e.metaKey) && e.shiftKey && k.toLowerCase() === 'z')) {
    e.preventDefault(); sheetRedo(); return;
  }
  // Navegación con flechas
  if (k === 'ArrowDown') { e.preventDefault(); sheetMove(0, 1); return; }
  if (k === 'ArrowUp')   { e.preventDefault(); sheetMove(0, -1); return; }
  if (k === 'ArrowLeft') { e.preventDefault(); sheetMove(-1, 0); return; }
  if (k === 'ArrowRight'){ e.preventDefault(); sheetMove(1, 0); return; }
  if (k === 'Tab')       { e.preventDefault(); sheetMove(e.shiftKey ? -1 : 1, 0); return; }
  // Enter / F2: editar
  if (k === 'Enter' || k === 'F2') { e.preventDefault(); sheetEditCell(SHEET.selected); return; }
  // Delete / Backspace: borrar selección o celda activa
  if (k === 'Delete' || k === 'Backspace') {
    e.preventDefault();
    sheetDeleteSelection();
    return;
  }
  // Caracter imprimible: empezar a editar la celda activa
  if (k.length === 1 && !(e.ctrlKey && !e.altKey) && !e.metaKey) {
    e.preventDefault();
    sheetEditCell(SHEET.selected, k);
  }
}

/* =========================================================================
   UNDO / REDO
   ========================================================================= */
function sheetSnapshot() {
  // Hace snapshot del estado actual de las celdas para historial
  return JSON.stringify(SHEET.cells);
}
function sheetRecordHistory() {
  if (!SHEET.history) SHEET.history = { stack: [], redo: [] };
  // Guardar el estado actual ANTES de modificar
  SHEET.history.stack.push(sheetSnapshot());
  if (SHEET.history.stack.length > 50) SHEET.history.stack.shift();
  // Cualquier acción nueva borra el historial de redo
  SHEET.history.redo = [];
}
function sheetUndo() {
  if (!SHEET.history || !SHEET.history.stack.length) {
    showToast('Nada para deshacer'); return;
  }
  // Empujar estado actual al redo
  SHEET.history.redo.push(sheetSnapshot());
  // Restaurar último estado
  const prev = SHEET.history.stack.pop();
  SHEET.cells = JSON.parse(prev);
  sheetRecalc(); sheetRender(); sheetSave();
  showToast('↶ Deshacer');
}
function sheetRedo() {
  if (!SHEET.history || !SHEET.history.redo.length) {
    showToast('Nada para rehacer'); return;
  }
  SHEET.history.stack.push(sheetSnapshot());
  const next = SHEET.history.redo.pop();
  SHEET.cells = JSON.parse(next);
  sheetRecalc(); sheetRender(); sheetSave();
  showToast('↷ Rehacer');
}

/* =========================================================================
   DELETE: borra todas las celdas seleccionadas (rango o celda activa)
   ========================================================================= */
function sheetDeleteSelection() {
  const targets = [];
  if (SHEET.range) {
    forEachCellInRange(SHEET.range.start, SHEET.range.end, addr => targets.push(addr));
  } else {
    targets.push(SHEET.selected);
  }
  // Sólo registrar historial si efectivamente hay algo que borrar
  const willDelete = targets.some(a => SHEET.cells[a]);
  if (!willDelete) return;
  sheetRecordHistory();
  for (const addr of targets) {
    delete SHEET.cells[addr];
  }
  sheetRecalc();
  sheetRender();
  sheetSave();
}

/* =========================================================================
   DRAG: selección de rango y range-picker durante edición de fórmula
   ========================================================================= */
function findEditingAddr() {
  const editing = document.querySelector('.sheet-cell.editing');
  return editing ? editing.dataset.addr : null;
}

function isEditingFormula(addr) {
  const div = document.getElementById('cell-' + addr);
  if (!div || !div.classList.contains('editing')) return false;
  const txt = (div.textContent || '').trim();
  return txt.startsWith('=');
}

function makeRangeStr(start, end) {
  if (start === end) return start;
  // Ordenar de modo que la celda superior-izquierda vaya primero
  const ms = start.match(/([A-Z]+)([0-9]+)/);
  const me = end.match(/([A-Z]+)([0-9]+)/);
  const c1 = ms[1].charCodeAt(0), r1 = parseInt(ms[2]);
  const c2 = me[1].charCodeAt(0), r2 = parseInt(me[2]);
  const cMin = String.fromCharCode(Math.min(c1, c2));
  const cMax = String.fromCharCode(Math.max(c1, c2));
  const rMin = Math.min(r1, r2), rMax = Math.max(r1, r2);
  return cMin + rMin + ':' + cMax + rMax;
}

function sheetCellMouseDown(addr, e) {
  // Click derecho o con modificador ctrl: ignorar (deja que pase contextmenu)
  if (e.button === 2) return;

  const editingAddr = findEditingAddr();
  if (editingAddr && editingAddr !== addr && isEditingFormula(editingAddr)) {
    // Modo: range-picker durante edición de fórmula
    e.preventDefault();
    const div = document.getElementById('cell-' + editingAddr);
    SHEET.dragState = {
      mode: 'range-pick',
      start: addr,
      current: addr,
      editingCell: editingAddr,
      textBefore: (div.textContent || '')
    };
    div.textContent = SHEET.dragState.textBefore + addr;
    document.getElementById('sheetFormulaBar').value = div.textContent;
    return;
  }

  if (editingAddr) return; // Si está editando ESTA celda, no hacer nada raro
  // Modo: selección normal o multi-select arrastrado
  SHEET.dragState = { mode: 'select', start: addr, current: addr };
  SHEET.range = null;
  sheetSelect(addr);
}

function sheetCellMouseEnter(addr) {
  const ds = SHEET.dragState;
  if (!ds) return;
  ds.current = addr;
  if (ds.mode === 'range-pick') {
    const div = document.getElementById('cell-' + ds.editingCell);
    const rangeStr = makeRangeStr(ds.start, ds.current);
    div.textContent = ds.textBefore + rangeStr;
    document.getElementById('sheetFormulaBar').value = div.textContent;
  } else if (ds.mode === 'select') {
    SHEET.range = (ds.start !== ds.current) ? { start: ds.start, end: ds.current } : null;
    highlightSheetRange();
  } else if (ds.mode === 'fill') {
    // Resaltar zona de relleno
    SHEET.fillRange = { start: ds.start, end: ds.current };
    highlightSheetRange();
  }
}

function sheetGlobalMouseUp() {
  const ds = SHEET.dragState;
  if (!ds) return;
  if (ds.mode === 'range-pick') {
    // Restaurar foco a la celda en edición, cursor al final
    setTimeout(() => {
      const div = document.getElementById('cell-' + ds.editingCell);
      if (!div) return;
      const range = document.createRange();
      range.selectNodeContents(div);
      range.collapse(false);
      const sel = window.getSelection();
      sel.removeAllRanges(); sel.addRange(range);
      div.focus();
    }, 10);
  } else if (ds.mode === 'fill') {
    sheetApplyFill(ds.start, ds.current);
    SHEET.fillRange = null;
    highlightSheetRange();
  }
  SHEET.dragState = null;
}

/* Resalta visualmente el rango seleccionado o de relleno */
function highlightSheetRange() {
  // Limpiar
  document.querySelectorAll('.sheet-cell.range-selected, .sheet-cell.fill-target')
    .forEach(c => c.classList.remove('range-selected', 'fill-target'));
  const r = SHEET.range;
  const f = SHEET.fillRange;
  if (r) {
    forEachCellInRange(r.start, r.end, addr => {
      const c = document.getElementById('cell-' + addr);
      if (c) c.classList.add('range-selected');
    });
  }
  if (f) {
    forEachCellInRange(f.start, f.end, addr => {
      if (addr === f.start) return;
      const c = document.getElementById('cell-' + addr);
      if (c) c.classList.add('fill-target');
    });
  }
}

function forEachCellInRange(a, b, fn) {
  const ma = a.match(/([A-Z]+)([0-9]+)/);
  const mb = b.match(/([A-Z]+)([0-9]+)/);
  if (!ma || !mb) return;
  const c1 = ma[1].charCodeAt(0), r1 = parseInt(ma[2]);
  const c2 = mb[1].charCodeAt(0), r2 = parseInt(mb[2]);
  for (let c = Math.min(c1, c2); c <= Math.max(c1, c2); c++) {
    for (let r = Math.min(r1, r2); r <= Math.max(r1, r2); r++) {
      fn(String.fromCharCode(c) + r);
    }
  }
}

/* Manija de relleno: copia/extiende celda hacia el rango arrastrado.
   Para fórmulas: ajusta referencias relativas. */
function sheetApplyFill(srcAddr, endAddr) {
  const src = SHEET.cells[srcAddr];
  if (!src || src.raw === '' || src.raw == null) return;
  sheetRecordHistory();
  const ms = srcAddr.match(/([A-Z]+)([0-9]+)/);
  const me = endAddr.match(/([A-Z]+)([0-9]+)/);
  const sc = ms[1].charCodeAt(0), sr = parseInt(ms[2]);
  const ec = me[1].charCodeAt(0), er = parseInt(me[2]);
  forEachCellInRange(srcAddr, endAddr, addr => {
    if (addr === srcAddr) return;
    const m = addr.match(/([A-Z]+)([0-9]+)/);
    const dCol = m[1].charCodeAt(0) - sc;
    const dRow = parseInt(m[2]) - sr;
    let raw = src.raw;
    if (typeof raw === 'string' && raw.startsWith('=')) {
      raw = shiftFormulaRefs(raw, dRow, dCol);
    }
    SHEET.cells[addr] = { raw, val: null, fmt: src.fmt };
  });
  sheetRecalc();
  sheetRender();
  sheetSave();
}

function shiftFormulaRefs(formula, dRow, dCol) {
  return formula.replace(/(\$?)([A-Z]+)(\$?)(\d+)/g, (m, dol1, col, dol2, row) => {
    const newCol = dol1 ? col : shiftCol(col, dCol);
    const newRow = dol2 ? row : (parseInt(row) + dRow);
    return dol1 + newCol + dol2 + newRow;
  });
}

function shiftCol(col, delta) {
  let n = 0;
  for (const c of col) n = n * 26 + (c.charCodeAt(0) - 64);
  n += delta;
  if (n < 1) n = 1;
  let res = '';
  while (n > 0) {
    res = String.fromCharCode(((n - 1) % 26) + 65) + res;
    n = Math.floor((n - 1) / 26);
  }
  return res;
}

function sheetMove(dx, dy) {
  const m = SHEET.selected.match(/([A-Z]+)([0-9]+)/);
  let c = m[1].charCodeAt(0) - 65 + dx;
  let r = parseInt(m[2]) + dy;
  c = Math.max(0, Math.min(SHEET.cols - 1, c));
  r = Math.max(1, Math.min(SHEET.rows, r));
  sheetSelect(colName(c) + r);
  document.getElementById('cell-' + SHEET.selected).focus();
}

function sheetSelect(addr) {
  // CRÍTICO: si hay una celda en edición distinta a la nueva, hacer commit ANTES de cambiar
  // Sin esto, el contenido raw queda visible "huérfano" y la fórmula se pierde.
  const editingAddr = findEditingAddr();
  if (editingAddr && editingAddr !== addr) {
    sheetCommitEditingCell();
  }

  // remove previous selection styling
  document.querySelectorAll('.sheet-cell.selected-display')
    .forEach(el => el.classList.remove('selected-display'));
  SHEET.selected = addr;
  // Si no estamos en medio de un drag, limpiar el rango
  if (!SHEET.dragState) {
    SHEET.range = null;
    document.querySelectorAll('.sheet-cell.range-selected').forEach(c => c.classList.remove('range-selected'));
  }
  const div = document.getElementById('cell-' + addr);
  if (div) div.classList.add('selected-display');
  document.getElementById('sheetNameBox').textContent = addr +
    (SHEET.range ? ':' + (SHEET.range.start === addr ? SHEET.range.end : SHEET.range.start) : '');
  // FÓRMULA VIVA: mostrar siempre el raw (fórmula) en la barra de fórmulas
  document.getElementById('sheetFormulaBar').value = (SHEET.cells[addr] || {}).raw || '';
  // Posicionar la manija de relleno
  positionFillHandle();
  sheetSave();
}

/* Hace commit del contenido de la celda en edición (si la hay) sin disparar blur. */
function sheetCommitEditingCell() {
  const div = document.querySelector('.sheet-cell.editing');
  if (!div) return;
  const addr = div.dataset.addr;
  const raw = div.textContent;
  div.contentEditable = 'false';
  div.classList.remove('editing');
  // Marcamos la bandera para que onBlur no haga doble commit
  div._committed = true;
  sheetSet(addr, raw);
}

function positionFillHandle() {
  const handle = document.getElementById('sheetFillHandle');
  if (!handle) return;
  // El target visual es la última celda del rango si existe, si no la celda seleccionada
  const targetAddr = SHEET.range
    ? makeRangeStr(SHEET.range.start, SHEET.range.end).split(':')[1]
    : SHEET.selected;
  const targetDiv = document.getElementById('cell-' + targetAddr);
  if (!targetDiv || !targetDiv.offsetParent) {
    handle.style.display = 'none';
    return;
  }
  const td = targetDiv.parentElement;
  const wrap = document.querySelector('.sheet-grid-wrap');
  if (!wrap || !td) { handle.style.display = 'none'; return; }
  const wrapRect = wrap.getBoundingClientRect();
  const tdRect = td.getBoundingClientRect();
  // Posición relativa al contenedor con scroll
  const left = tdRect.right - wrapRect.left + wrap.scrollLeft - 4;
  const top = tdRect.bottom - wrapRect.top + wrap.scrollTop - 4;
  handle.style.left = left + 'px';
  handle.style.top = top + 'px';
  handle.style.display = 'block';
}

function sheetEditCell(addr, initial) {
  // Si hay otra celda en edición, hacer commit primero
  const otherEditing = findEditingAddr();
  if (otherEditing && otherEditing !== addr) sheetCommitEditingCell();

  sheetSelect(addr);
  const div = document.getElementById('cell-' + addr);
  // Quitar formato visual mientras se edita (para que no aparezca con $/%)
  div.classList.remove('fmt-currency', 'fmt-percent', 'text', 'error');
  div.classList.add('editing');
  div.contentEditable = 'true';
  div._committed = false; // resetear bandera
  // CLAVE: limpiar el div antes de asignar el contenido raw (evita que se muestre el valor formateado)
  div.innerHTML = '';
  const current = (SHEET.cells[addr] || {}).raw || '';
  const startContent = initial != null ? initial : current;
  div.textContent = startContent;
  // Sincronizar barra de fórmulas
  document.getElementById('sheetFormulaBar').value = startContent;
  // place caret at end
  const range = document.createRange();
  range.selectNodeContents(div);
  range.collapse(false);
  const sel = window.getSelection();
  sel.removeAllRanges(); sel.addRange(range);
  div.focus();

  const finish = (commit, moveDir) => {
    if (div._committed) {
      // Ya se hizo commit por sheetCommitEditingCell, sólo movemos si aplica
      if (moveDir) sheetMove(moveDir.dx, moveDir.dy);
      div.removeEventListener('blur', onBlur);
      div.removeEventListener('keydown', onKey);
      return;
    }
    const raw = div.textContent;
    div.contentEditable = 'false';
    div.classList.remove('editing');
    div._committed = true;
    if (commit) sheetSet(addr, raw);
    else sheetRender();
    if (moveDir) sheetMove(moveDir.dx, moveDir.dy);
    div.removeEventListener('blur', onBlur);
    div.removeEventListener('keydown', onKey);
  };
  const onBlur = () => {
    // No hacer finish si lo que hicimos fue arrastrar para range-picking
    if (SHEET.dragState && SHEET.dragState.mode === 'range-pick') return;
    // Pequeño delay para dejar que mousedown en otra celda haga su commit primero
    setTimeout(() => { if (!div._committed) finish(true); }, 0);
  };
  const onKey = (e) => {
    if (e.key === 'Enter') { e.preventDefault(); finish(true, { dx: 0, dy: 1 }); }
    else if (e.key === 'Tab') { e.preventDefault(); finish(true, { dx: e.shiftKey ? -1 : 1, dy: 0 }); }
    else if (e.key === 'Escape') { e.preventDefault(); finish(false); }
  };
  div.addEventListener('blur', onBlur);
  div.addEventListener('keydown', onKey);
}

function sheetSet(addr, raw) {
  // Registrar historial sólo si hay un cambio real
  const before = SHEET.cells[addr] ? SHEET.cells[addr].raw : '';
  if (String(before) !== String(raw)) sheetRecordHistory();
  if (raw === '' || raw == null) {
    delete SHEET.cells[addr];
  } else {
    // Conservar formato si la celda ya existía
    const existingFmt = SHEET.cells[addr] ? SHEET.cells[addr].fmt : undefined;
    SHEET.cells[addr] = { raw, val: null, fmt: existingFmt };
  }
  sheetRecalc();
  sheetRender();
  sheetSave();
}

function sheetClear() {
  if (!confirm("¿Borrar todo el contenido de la hoja?")) return;
  SHEET.cells = {};
  sheetRecalc(); sheetRender(); sheetSave();
}

/* Evaluate one raw value */
function sheetEvalRaw(raw, stack) {
  if (raw == null || raw === '') return '';
  if (typeof raw === 'number') return raw;
  const trimmed = String(raw).trim();
  if (!trimmed.startsWith('=')) {
    // Valor directo: detectar moneda, porcentaje o número plano
    // Moneda: "$1,000.50" o "1,000.50" → 1000.50
    if (/^-?\$?[\d,]+(\.\d+)?$/.test(trimmed)) {
      const cleaned = trimmed.replace(/[$,]/g, '');
      const n = parseFloat(cleaned);
      return isNaN(n) ? trimmed : n;
    }
    // Porcentaje: "15.5%" → 0.155
    if (/^-?\d+(\.\d+)?%$/.test(trimmed)) {
      const n = parseFloat(trimmed.slice(0, -1));
      return isNaN(n) ? trimmed : n / 100;
    }
    // Número plano
    const n = parseFloat(trimmed);
    return isNaN(n) ? trimmed : n;
  }
  let expr = trimmed.slice(1);

  // Recursion guard
  stack = stack || new Set();

  // Convertir porcentajes literales en fórmulas: "15%" → "(15/100)"
  // Word boundary \b para no afectar referencias de celda como A15
  expr = expr.replace(/\b(\d+(?:\.\d+)?)%/g, '($1/100)');

  // Functions (apply repeatedly to handle nested)
  for (let i = 0; i < 5; i++) {
    const before = expr;
    expr = expr.replace(/SUM\(([^()]+)\)/gi, (_, args) => {
      const cells = sheetExpandArgs(args);
      const vals = cells.map(c => Number(sheetGetVal(c, stack)) || 0);
      return '(' + (vals.reduce((a, b) => a + b, 0)) + ')';
    });
    expr = expr.replace(/AVERAGE\(([^()]+)\)/gi, (_, args) => {
      const cells = sheetExpandArgs(args);
      const vals = cells.map(c => Number(sheetGetVal(c, stack)) || 0);
      const avg = vals.length ? vals.reduce((a, b) => a + b, 0) / vals.length : 0;
      return '(' + avg + ')';
    });
    expr = expr.replace(/POWER\(([^,()]+),([^()]+)\)/gi, (_, a, b) =>
      `((${sheetReplaceRefs(a, stack)})**(${sheetReplaceRefs(b, stack)}))`);
    expr = expr.replace(/ROUND\(([^,()]+),([^()]+)\)/gi, (_, a, b) =>
      `(Math.round((${sheetReplaceRefs(a, stack)})*Math.pow(10,${sheetReplaceRefs(b, stack)}))/Math.pow(10,${sheetReplaceRefs(b, stack)}))`);
    expr = expr.replace(/ABS\(([^()]+)\)/gi, (_, a) => `Math.abs(${sheetReplaceRefs(a, stack)})`);
    expr = expr.replace(/IF\(([^,()]+),([^,()]+),([^()]+)\)/gi, (_, c, a, b) =>
      `((${sheetReplaceRefs(c, stack)}) ? (${sheetReplaceRefs(a, stack)}) : (${sheetReplaceRefs(b, stack)}))`);
    if (expr === before) break;
  }

  // Replace cell refs (outside functions)
  expr = sheetReplaceRefs(expr, stack);

  // Replace ^ with **
  expr = expr.replace(/\^/g, '**');

  // Whitelist
  if (!/^[0-9+\-*/().\s*<>=!&|?:]+$/.test(expr.replace(/Math\.\w+/g, ''))) {
    return '#ERR';
  }
  try {
    const result = Function('"use strict"; return (' + expr + ')')();
    if (typeof result !== 'number' || !isFinite(result)) return '#ERR';
    return result;
  } catch (e) {
    return '#ERR';
  }
}

function sheetReplaceRefs(expr, stack) {
  return String(expr).replace(/\$?([A-Z]+)\$?([0-9]+)/g, (m, c, r) => {
    const addr = c + r;
    const v = sheetGetVal(addr, stack);
    return '(' + (typeof v === 'number' ? v : 0) + ')';
  });
}

function sheetGetVal(addr, stack) {
  stack = stack || new Set();
  if (stack.has(addr)) return 0; // circular
  const cell = SHEET.cells[addr];
  if (!cell) return 0;
  stack.add(addr);
  const v = sheetEvalRaw(cell.raw, stack);
  stack.delete(addr);
  return v;
}

function sheetExpandArgs(args) {
  const cells = [];
  for (const part of args.split(',')) {
    const p = part.trim();
    if (p.includes(':')) {
      const [a, b] = p.split(':').map(s => s.replace(/\$/g, '').trim());
      const ma = a.match(/([A-Z]+)([0-9]+)/);
      const mb = b.match(/([A-Z]+)([0-9]+)/);
      if (ma && mb) {
        const c1 = ma[1].charCodeAt(0), c2 = mb[1].charCodeAt(0);
        const r1 = parseInt(ma[2]), r2 = parseInt(mb[2]);
        for (let c = Math.min(c1, c2); c <= Math.max(c1, c2); c++) {
          for (let r = Math.min(r1, r2); r <= Math.max(r1, r2); r++) {
            cells.push(String.fromCharCode(c) + r);
          }
        }
      }
    } else if (p) {
      cells.push(p.replace(/\$/g, ''));
    }
  }
  return cells;
}

function sheetRecalc() {
  for (const addr of Object.keys(SHEET.cells)) {
    SHEET.cells[addr].val = sheetEvalRaw(SHEET.cells[addr].raw);
  }
}

function sheetFormatValue(v, fmt, decimals) {
  if (typeof v !== 'number' || !isFinite(v)) return v == null ? '' : String(v);
  const dec = decimals != null ? decimals : 2;
  if (fmt === 'currency') {
    const sign = v < 0 ? '-' : '';
    return sign + '$' + Math.abs(v).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }
  if (fmt === 'percent') {
    return (v * 100).toLocaleString('en-US', { minimumFractionDigits: dec, maximumFractionDigits: dec }) + '%';
  }
  if (fmt === 'number2') {
    return v.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }
  if (fmt === 'integer') {
    return Math.round(v).toLocaleString('en-US');
  }
  // Default: 4 decimals max, with thousand separators if big
  return Math.abs(v) >= 1000
    ? v.toLocaleString('en-US', { maximumFractionDigits: 4 })
    : Number(v.toFixed(6)).toString();
}

function sheetRender() {
  for (let r = 1; r <= SHEET.rows; r++) {
    for (let c = 0; c < SHEET.cols; c++) {
      const addr = colName(c) + r;
      const div = document.getElementById('cell-' + addr);
      if (!div || div.classList.contains('editing')) continue;
      const cell = SHEET.cells[addr];
      div.classList.remove('text', 'error', 'fmt-currency', 'fmt-percent', 'has-formula');
      if (!cell) { div.textContent = ''; continue; }
      const v = cell.val;
      const isFormula = typeof cell.raw === 'string' && cell.raw.startsWith('=');
      if (isFormula) div.classList.add('has-formula');
      if (v === '#ERR') { div.textContent = '#ERR'; div.classList.add('error'); }
      else if (typeof v === 'number') {
        div.textContent = sheetFormatValue(v, cell.fmt);
        if (cell.fmt === 'currency') div.classList.add('fmt-currency');
        if (cell.fmt === 'percent') div.classList.add('fmt-percent');
      } else {
        div.textContent = v == null ? '' : String(v);
        div.classList.add('text');
      }
    }
  }
  // re-apply selection
  const sel = document.getElementById('cell-' + SHEET.selected);
  if (sel) sel.classList.add('selected-display');
  // Update format indicator in name box
  updateSheetFormatIndicator();
  // Refrescar barra de fórmulas con el raw de la celda activa (fórmula viva)
  const fb = document.getElementById('sheetFormulaBar');
  if (fb && document.activeElement !== fb) {
    fb.value = (SHEET.cells[SHEET.selected] || {}).raw || '';
  }
  // Reposicionar manija de relleno
  positionFillHandle();
}

function updateSheetFormatIndicator() {
  const cell = SHEET.cells[SHEET.selected];
  const fmt = cell && cell.fmt;
  const buttons = {
    'fmt-currency-btn': 'currency',
    'fmt-percent-btn': 'percent',
    'fmt-num2-btn': 'number2'
  };
  for (const id of Object.keys(buttons)) {
    const btn = document.getElementById(id);
    if (btn) btn.classList.toggle('active', fmt === buttons[id]);
  }
}

function sheetFormatCell(fmt) {
  // Determinar el conjunto de celdas a las que aplicar el formato
  const targets = [];
  if (SHEET.range) {
    forEachCellInRange(SHEET.range.start, SHEET.range.end, addr => targets.push(addr));
  } else {
    targets.push(SHEET.selected);
  }
  sheetRecordHistory();

  // Si todas ya tienen ese mismo formato, lo quitamos (toggle).
  // En caso contrario, aplicamos el formato a todas.
  const allHave = targets.every(a => SHEET.cells[a] && SHEET.cells[a].fmt === fmt);

  for (const addr of targets) {
    if (!SHEET.cells[addr]) {
      SHEET.cells[addr] = { raw: '', val: '' };
    }
    if (allHave || fmt === null) {
      delete SHEET.cells[addr].fmt;
    } else {
      SHEET.cells[addr].fmt = fmt;
    }
    if (!SHEET.cells[addr].raw && !SHEET.cells[addr].fmt) {
      delete SHEET.cells[addr];
    }
  }
  sheetSave();
  sheetRender();
}

function openSheet(qid) {
  const targetQid = qid || getActiveCalcQid();
  if (!targetQid) {
    alert('No hay un reactivo de cálculo en esta sección.');
    return;
  }
  sheetLoadForQuestion(targetQid);
  // Reiniciar historial al cambiar de pregunta
  SHEET.history = { stack: [], redo: [] };
  document.getElementById('sheetModal').classList.remove('hidden');
  document.body.classList.add('sheet-open'); // encoger contenedor de preguntas
  if (!document.getElementById('sheetTable').children.length) sheetBuild();
  sheetRecalc();
  sheetRender();
  sheetSelect(SHEET.selected);

  const ref = findQuestion(targetQid);
  if (ref) {
    const cellsCount = Object.keys(SHEET.cells).filter(a => SHEET.cells[a].raw !== '' && SHEET.cells[a].raw != null).length;
    document.getElementById('sheetCtx').textContent =
      `Pregunta ${targetQid.toUpperCase()} · Sección ${ref.sec.id} · ${cellsCount} celdas con datos`;
  }
  setTimeout(() => {
    const focusCell = document.getElementById('cell-' + SHEET.selected);
    if (focusCell) focusCell.focus();
  }, 50);
}
function closeSheet() {
  document.getElementById('sheetModal').classList.add('hidden');
  document.body.classList.remove('sheet-open');
}

/* =========================================================================
   APLICAR HOJA A LA RESPUESTA
   ========================================================================= */
function sheetApplyToQuestion() {
  if (!SHEET.activeQid) { alert('No hay pregunta activa.'); return; }
  const ref = findQuestion(SHEET.activeQid);
  if (!ref) return;
  const text = sheetSerialize();
  if (!text) { alert('La hoja está vacía. Llena al menos una celda antes de aplicar.'); return; }

  const qid = SHEET.activeQid;
  // Guardar snapshot de los datos para que el docente vea la hoja exacta
  state.session.answers[qid + '_sheet_data'] = JSON.stringify(SHEET.cells);
  state.session.answers[qid + '_sheet_applied_at'] = Date.now();

  if (ref.q.type === 'calc') {
    // En cálculo: la hoja reemplaza el procedimiento (el alumno puede agregar texto después)
    state.session.answers[qid + '_proc'] = text;
  } else if (ref.q.type === 'open') {
    // En abiertas: si ya había una hoja aplicada, reemplazar ese bloque; si no, anexar
    const existing = state.session.answers[qid] || '';
    const cleaned = existing.replace(/\[Hoja de cálculo aplicada[\s\S]*?(?=\n\n|$)/g, '').trim();
    state.session.answers[qid] = cleaned ? (cleaned + '\n\n' + text) : text;
  }

  saveCurrentSession();
  // Re-renderizar la pregunta para mostrar el contenido en el textarea
  renderQuestions();
  showToast('✓ Hoja aplicada como respuesta de la pregunta ' + qid.toUpperCase());
}

function sheetSerialize() {
  const addrs = Object.keys(SHEET.cells).filter(a => {
    const c = SHEET.cells[a];
    return c && c.raw !== '' && c.raw != null;
  }).sort((a, b) => {
    const ma = a.match(/([A-Z]+)([0-9]+)/), mb = b.match(/([A-Z]+)([0-9]+)/);
    const ra = parseInt(ma[2]), rb = parseInt(mb[2]);
    if (ra !== rb) return ra - rb;
    return ma[1].localeCompare(mb[1]);
  });
  if (!addrs.length) return '';
  const lines = [];
  lines.push('[Hoja de cálculo aplicada · ' + new Date().toLocaleString() + ']');
  lines.push('Celda  | Fórmula / valor                  | Resultado');
  lines.push('-------+----------------------------------+------------------');
  for (const a of addrs) {
    const cell = SHEET.cells[a];
    const valStr = (typeof cell.val === 'number')
      ? cell.val.toLocaleString('en-US', { maximumFractionDigits: 4 })
      : (cell.val == null ? '' : String(cell.val));
    lines.push(a.padEnd(6) + ' | ' + String(cell.raw).padEnd(32).slice(0, 32) + ' | ' + valStr);
  }
  return lines.join('\n');
}

function showToast(msg) {
  let toast = document.getElementById('toastMsg');
  if (!toast) {
    toast = document.createElement('div');
    toast.id = 'toastMsg';
    toast.style.cssText = 'position:fixed;bottom:30px;left:50%;transform:translateX(-50%);background:#1e7e34;color:white;padding:14px 28px;border-radius:10px;font-weight:700;z-index:200;box-shadow:0 8px 24px rgba(0,0,0,.3);transition:opacity .35s;';
    document.body.appendChild(toast);
  }
  toast.textContent = msg;
  toast.style.opacity = '1';
  toast.style.display = 'block';
  clearTimeout(window._toastTimer);
  window._toastTimer = setTimeout(() => { toast.style.opacity = '0'; setTimeout(() => toast.style.display = 'none', 350); }, 2400);
}

/* =========================================================================
   BOTONES DE LA BARRA DE HERRAMIENTAS
   Insertan operadores/funciones en la celda activa o continúan editándola.
   Auto-prefijan "=" cuando se inserta un operador o función y la celda
   todavía no es una fórmula. Así el alumno puede simplemente apretar
   "POWER" en una celda vacía y obtener "=POWER(".
   ========================================================================= */
function sheetInsertText(text) {
  const addr = SHEET.selected || 'A1';
  const div = document.getElementById('cell-' + addr);
  if (!div) return;

  // ¿Este texto convierte la celda en fórmula? (operadores y nombres de función)
  const isFormulaTrigger = /^[+\-*/^]$/.test(text) || /^[A-Z]+\($/.test(text);

  // Tomar contenido actual (de edición en vivo, o del valor guardado)
  let content = div.classList.contains('editing')
    ? (div.textContent || '')
    : ((SHEET.cells[addr] || {}).raw || '');

  if (text === '=') {
    // Botón "=" : asegurar que la celda inicie con "=" pero sin duplicar
    if (!content.startsWith('=')) content = '=' + content;
  } else if (isFormulaTrigger && !content.startsWith('=')) {
    // Operador o función en celda que no es fórmula → prefijar "="
    content = '=' + content + text;
  } else {
    // Inserción simple al final (paréntesis, coma, dos puntos, punto decimal,
    // o cualquier inserción cuando la celda ya es fórmula)
    content = content + text;
  }

  if (div.classList.contains('editing')) {
    div.textContent = content;
    document.getElementById('sheetFormulaBar').value = content;
    // mover cursor al final
    const range = document.createRange();
    range.selectNodeContents(div);
    range.collapse(false);
    const sel = window.getSelection();
    sel.removeAllRanges(); sel.addRange(range);
    div.focus();
  } else {
    // Entrar en edición con el contenido nuevo
    sheetEditCell(addr, content);
  }
}

function sheetFillHandleDown(e) {
  e.preventDefault();
  e.stopPropagation();
  // El origen del relleno es la celda actualmente seleccionada o la del último rango
  const startAddr = SHEET.range
    ? makeRangeStr(SHEET.range.start, SHEET.range.end).split(':')[1]
    : SHEET.selected;
  SHEET.dragState = { mode: 'fill', start: startAddr, current: startAddr };
}

function sheetCommitCurrent() {
  const addr = SHEET.selected || 'A1';
  const div = document.getElementById('cell-' + addr);
  if (!div) return;
  if (div.classList.contains('editing')) {
    // Disparar blur para que se confirme via finish(true)
    div.blur();
  } else {
    // Si está la barra de fórmulas con valor, aplicarlo
    const fb = document.getElementById('sheetFormulaBar');
    if (fb && fb.value !== ((SHEET.cells[addr] || {}).raw || '')) {
      sheetSet(addr, fb.value);
    }
  }
  // Mover a la siguiente fila
  setTimeout(() => sheetMove(0, 1), 50);
}

/* Show/hide the sheet button depending on current section's question types */
function updateSheetButton() {
  if (!state.session || state.role !== 'student') {
    document.getElementById('sheetFab').classList.add('hidden');
    return;
  }
  const sec = state.bank.sections[state.session.currentSection];
  const hasCalc = sec.questions.some(q => SHEET.visibleQTypes.includes(q.type));
  document.getElementById('sheetFab').classList.toggle('hidden', !hasCalc);
  // Update context label
  const ctx = sec.questions.filter(q => SHEET.visibleQTypes.includes(q.type)).length;
  document.getElementById('sheetCtx').textContent =
    `Sección ${sec.id} · ${ctx} reactivo(s) requieren cálculo`;
}

// Init
init();
