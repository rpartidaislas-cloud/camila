/* =========================================================================
   ADMIN: STUDENTS MANAGEMENT
   ========================================================================= */
function genCode() {
  const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
  let s = '';
  for (let i = 0; i < 6; i++) s += chars[Math.floor(Math.random() * chars.length)];
  return s;
}

function getStudents() { return loadStore(STORE_KEYS.students, []); }
function setStudents(list) { saveStore(STORE_KEYS.students, list); renderStudents(); }

function addStudent() {
  const name = document.getElementById('newStudentName').value.trim();
  let code = document.getElementById('newStudentCode').value.trim().toUpperCase();
  if (!name) return alert("Ingresa el nombre del alumno");
  const list = getStudents();
  if (!code) {
    do { code = genCode(); } while (list.find(s => s.code === code));
  } else {
    if (list.find(s => s.code.toUpperCase() === code)) return alert("Ya existe un alumno con ese código.");
  }
  list.push({ name, code });
  setStudents(list);
  document.getElementById('newStudentName').value = '';
  document.getElementById('newStudentCode').value = '';
}

function removeStudent(code) {
  if (!confirm("¿Eliminar este alumno?")) return;
  setStudents(getStudents().filter(s => s.code !== code));
}

function clearStudents() {
  if (!confirm("¿Borrar TODOS los alumnos registrados?")) return;
  setStudents([]);
}

function importStudents(ev) {
  const file = ev.target.files[0];
  if (!file) return;
  const isExcel = /\.xlsx?$/i.test(file.name);

  if (isExcel) {
    ensureXLSX().then(() => {
      const reader = new FileReader();
      reader.onload = e => {
        try {
          const wb = window.XLSX.read(e.target.result, { type: 'array' });
          const sheet = wb.Sheets[wb.SheetNames[0]];
          const rows = window.XLSX.utils.sheet_to_json(sheet, { header: 1, raw: false, defval: '' });
          processStudentRows(rows);
        } catch (err) {
          alert('Error al leer Excel: ' + err.message);
        }
        ev.target.value = '';
      };
      reader.readAsArrayBuffer(file);
    }).catch(() => {
      alert('No se pudo cargar el lector de Excel. Verifica tu conexión a internet, o guarda el archivo como CSV desde Excel y vuelve a intentar.');
      ev.target.value = '';
    });
    return;
  }

  // CSV / TXT
  const reader = new FileReader();
  reader.onload = e => {
    const text = e.target.result;
    const rows = text.split(/\r?\n/).map(l => l.trim()).filter(l => l && !l.startsWith('#')).map(l => l.split(',').map(s => s.trim()));
    processStudentRows(rows);
    ev.target.value = '';
  };
  reader.readAsText(file);
}

function processStudentRows(rows) {
  const list = getStudents();
  let added = 0, skipped = 0;
  for (const row of rows) {
    if (!row || !row.length) continue;
    const name = String(row[0] || '').trim();
    if (!name) continue;
    // Saltar fila de encabezado común
    if (/^(nombre|name|alumno|estudiante)$/i.test(name)) continue;
    let code = String(row[1] || '').trim().toUpperCase();
    if (!code) {
      do { code = genCode(); } while (list.find(s => s.code === code));
    } else if (list.find(s => s.code.toUpperCase() === code)) {
      skipped++; continue;
    }
    list.push({ name, code });
    added++;
  }
  setStudents(list);
  alert(`✓ Se agregaron ${added} alumnos.${skipped > 0 ? ' (' + skipped + ' duplicados omitidos)' : ''}`);
}

// Carga diferida de SheetJS (xlsx) sólo cuando se necesita
function ensureXLSX() {
  if (window.XLSX) return Promise.resolve();
  if (window._xlsxLoadPromise) return window._xlsxLoadPromise;
  window._xlsxLoadPromise = new Promise((resolve, reject) => {
    const script = document.createElement('script');
    script.src = 'https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js';
    script.onload = () => resolve();
    script.onerror = () => reject(new Error('No se pudo cargar SheetJS'));
    document.head.appendChild(script);
  });
  return window._xlsxLoadPromise;
}

/* Permitir reintento: el docente activa la posibilidad de re-tomar el examen
   para un alumno específico. Tras el reenvío, el flag se quita automáticamente. */
function toggleRetake(code) {
  const list = getStudents();
  const s = list.find(st => st.code === code);
  if (!s) return;
  s.allowsRetake = !s.allowsRetake;
  setStudents(list);
  showToast(s.allowsRetake
    ? `🔓 ${s.name} podrá volver a tomar el examen una vez más.`
    : `🔒 Reintento revocado para ${s.name}.`);
}

function exportStudents(mode) {
  const list = getStudents();
  if (!list.length) return alert("No hay alumnos para exportar.");
  let content;
  if (mode === 'codes') {
    content = "ALUMNO,CÓDIGO DE ACCESO\n" + list.map(s => `${s.name},${s.code}`).join("\n");
  } else {
    content = list.map(s => `${s.name},${s.code}`).join("\n");
  }
  downloadFile('alumnos_codigos.csv', content, 'text/csv');
}

function downloadFile(filename, content, type) {
  const blob = new Blob([content], { type: type || 'text/plain' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url; a.download = filename;
  document.body.appendChild(a); a.click(); a.remove();
  URL.revokeObjectURL(url);
}

function renderStudents() {
  const list = getStudents();
  const results = loadStore(STORE_KEYS.results, []);
  const box = document.getElementById('studentsList');
  if (!list.length) { box.innerHTML = "<p class='muted'>Aún no hay alumnos registrados.</p>"; return; }
  box.innerHTML = list.map(s => {
    const taken = results.filter(r => r.studentCode === s.code);
    const tookExam = taken.length > 0;
    let actionBtn;
    if (!tookExam) {
      actionBtn = `<button class="btn btn-sm btn-ghost" onclick="removeStudent('${s.code}')" style="color:var(--accent);border-color:var(--accent)" title="Eliminar alumno">🗑️</button>`;
    } else if (s.allowsRetake) {
      actionBtn = `<button class="btn btn-sm" onclick="toggleRetake('${s.code}')" style="background:#1e7e34;color:white;border:1px solid #1e7e34" title="Click para revocar el permiso">🔓 Reintento permitido</button>`;
    } else {
      actionBtn = `<button class="btn btn-sm" onclick="toggleRetake('${s.code}')" style="background:transparent;color:#1e7e34;border:1px solid #1e7e34" title="Click para autorizar un nuevo intento">🔓 Permitir reintento</button>`;
    }
    return `<div class="student-row ${tookExam ? 'taken' : ''}">
      <span class="name">${escapeHTML(s.name)}${taken.length > 1 ? ' <span class="muted" style="font-size:11px">('+ taken.length +' intentos)</span>' : ''}</span>
      <span class="code">${s.code}</span>
      ${actionBtn}
    </div>`;
  }).join("");
}

