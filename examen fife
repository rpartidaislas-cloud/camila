/* =========================================================================
   MATCH QUESTION (drag-and-drop)
   ========================================================================= */
function renderMatchQuestion(q) {
  const ans = state.session.answers[q.id] || {};
  // Build the right-side pool with shuffled values (deterministic by qid)
  const rightValues = (q.pairs || []).map(p => p.right);
  // Use a stable shuffle based on qid hash
  const shuffled = stableShuffle(rightValues, q.id);

  let html = `<p class="muted" style="font-size:13px">📌 Arrastra cada elemento de la derecha hacia el cuadro de la izquierda al que corresponde.</p>`;
  html += `<div class="match-wrapper" data-qid="${q.id}">`;
  // Left column with slots
  html += `<div class="match-col"><h4>📋 Elementos</h4>`;
  (q.pairs || []).forEach((p, pi) => {
    const placed = ans[p.left];
    html += `<div class="match-item" data-left="${escapeHTML(p.left)}">
      <span class="label">${escapeHTML(p.left)}</span>
      <div class="slot ${placed ? 'filled' : ''}" data-qid="${q.id}" data-left="${escapeHTML(p.left)}"
           ondragover="matchDragOver(event)" ondragleave="matchDragLeave(event)" ondrop="matchDrop(event)">
        ${placed ? `<span class="placed">${escapeHTML(placed)}</span>
          <button class="placed-remove" onclick="matchRemove('${q.id}', '${escapeHTML(p.left)}')" title="Quitar">✕</button>` : '<span>Suelta aquí…</span>'}
      </div>
    </div>`;
  });
  html += `</div>`;
  // Right column: pool of draggables
  html += `<div class="match-col match-pool" data-qid="${q.id}"><h4>🔘 Opciones (arrastra)</h4>`;
  const usedRights = new Set(Object.values(ans));
  shuffled.forEach((val, i) => {
    const placed = usedRights.has(val);
    html += `<div class="draggable ${placed ? 'placed' : ''}" draggable="true" data-value="${escapeHTML(val)}"
                  ondragstart="matchDragStart(event)" ondragend="matchDragEnd(event)">${escapeHTML(val)}</div>`;
  });
  html += `</div></div>`;
  return html;
}

// deterministic shuffle: avoids reshuffling on each render
function stableShuffle(arr, seedStr) {
  let h = 0;
  for (const c of seedStr) h = ((h << 5) - h) + c.charCodeAt(0);
  const a = arr.slice();
  for (let i = a.length - 1; i > 0; i--) {
    h = (h * 9301 + 49297) % 233280;
    const j = Math.abs(h) % (i + 1);
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

function initMatchDragDrop() {
  // listeners ya están en los atributos onX, no hace falta nada extra aquí
  // (placeholder para futuras necesidades como touch events)
}

function matchDragStart(ev) {
  ev.dataTransfer.setData('text/plain', ev.target.dataset.value);
  ev.target.classList.add('dragging');
}
function matchDragEnd(ev) {
  ev.target.classList.remove('dragging');
}
function matchDragOver(ev) {
  ev.preventDefault();
  ev.currentTarget.classList.add('dragover');
}
function matchDragLeave(ev) {
  ev.currentTarget.classList.remove('dragover');
}
function matchDrop(ev) {
  ev.preventDefault();
  ev.currentTarget.classList.remove('dragover');
  const value = ev.dataTransfer.getData('text/plain');
  const qid = ev.currentTarget.dataset.qid;
  const left = ev.currentTarget.dataset.left;
  if (!state.session.answers[qid]) state.session.answers[qid] = {};
  // Si este 'value' ya estaba asignado a otra fila, quitarlo de allí
  for (const k of Object.keys(state.session.answers[qid])) {
    if (state.session.answers[qid][k] === value) delete state.session.answers[qid][k];
  }
  state.session.answers[qid][left] = value;
  saveCurrentSession();
  renderQuestions();
}
function matchRemove(qid, left) {
  if (state.session.answers[qid]) delete state.session.answers[qid][left];
  saveCurrentSession();
  renderQuestions();
}

function answerQ(qid, idx) {
  state.session.answers[qid] = idx;
  saveCurrentSession();
  updateProgress();
  goSection(state.session.currentSection); // refresh section nav done indicator
}
function answerProc(qid, val) {
  state.session.answers[qid + '_proc'] = val;
  saveCurrentSession();
}
function answerOpen(qid, val) {
  state.session.answers[qid] = val;
  saveCurrentSession();
  updateProgress();
}

function updateProgress() {
  const all = state.bank.sections.flatMap(s => s.questions);
  const answered = all.filter(q => {
    const a = state.session.answers[q.id];
    if (q.type === 'match') {
      // Considerar respondida si todos los pares tienen valor
      if (!a || typeof a !== 'object') return false;
      return (q.pairs || []).every(p => a[p.left]);
    }
    return a !== undefined && a !== "" && a !== null;
  }).length;
  const pct = (answered / all.length) * 100;
  document.getElementById('progressBar').style.width = pct + '%';
  document.getElementById('progressLabel').innerHTML =
    `${answered} / ${all.length} reactivos respondidos · <span id="autosaveLabel" class="save-indicator">✓ Auto-guardado activo</span>`;
}

function escapeHTML(s) {
  return String(s == null ? '' : s)
    .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
}

/* =========================================================================
   TIMER
   ========================================================================= */
function startTimer() {
  // Use sessionDuration on first start; if resuming, recompute from startedAt
  const totalMs = state.session.durationMin * 60 * 1000;
  state.endsAt = state.session.startedAt + totalMs;
  if (state.timerId) clearInterval(state.timerId);
  tick();
  state.timerId = setInterval(tick, 500);
}
function tick() {
  const remaining = state.endsAt - Date.now();
  const el = document.getElementById('timerDisplay');
  if (remaining <= 0) {
    el.textContent = "00:00";
    submitExam('timeout');
    return;
  }
  const mins = Math.floor(remaining / 60000);
  const secs = Math.floor((remaining % 60000) / 1000);
  const hrs = Math.floor(mins / 60);
  const mm = (mins % 60).toString().padStart(2, '0');
  const ss = secs.toString().padStart(2, '0');
  el.textContent = hrs > 0 ? `${hrs}:${mm}:${ss}` : `${mm}:${ss}`;
  el.classList.toggle('warn', remaining < 60000); // last minute
}

/* =========================================================================
   AUTO-SAVE (cada 5s)
   ========================================================================= */
function startAutoSave() {
  if (state.autosaveTimer) clearInterval(state.autosaveTimer);
  state.autosaveTimer = setInterval(() => {
    saveCurrentSession();
  }, 5000);
}

/* =========================================================================
   ANTI-TRAMPA
   ========================================================================= */
function installAntiCheat() {
  document.addEventListener('visibilitychange', onVisibilityChange);
  window.addEventListener('blur', onBlur);
  window.addEventListener('focus', onFocus);
  document.addEventListener('contextmenu', preventContextMenu);
  document.addEventListener('copy', onCopyAttempt);
  document.addEventListener('paste', onPasteAttempt);
  document.addEventListener('keydown', onKeyDown);
  ['mousemove', 'keydown', 'click', 'scroll', 'touchstart'].forEach(ev =>
    document.addEventListener(ev, resetIdleTimer, { passive: true }));
  resetIdleTimer();
}

function removeAntiCheat() {
  document.removeEventListener('visibilitychange', onVisibilityChange);
  window.removeEventListener('blur', onBlur);
  window.removeEventListener('focus', onFocus);
  document.removeEventListener('contextmenu', preventContextMenu);
  document.removeEventListener('copy', onCopyAttempt);
  document.removeEventListener('paste', onPasteAttempt);
  document.removeEventListener('keydown', onKeyDown);
  if (state.idleTimer) clearTimeout(state.idleTimer);
}

function isInsideSheet(e) {
  const modal = document.getElementById('sheetModal');
  if (!modal || modal.classList.contains('hidden')) return false;
  return modal.contains(e.target);
}

function onVisibilityChange() {
  if (document.hidden) raiseAlert("Cambio de pestaña / ventana oculta", "warn",
    "El usuario cambió de pestaña o minimizó la ventana");
}
function onBlur() {
  raiseAlert("Pérdida de foco de la ventana", "warn",
    "Posible Alt+Tab, cambio de aplicación o minimización");
}
function onFocus() {
  // info-level
  logEvent("Ventana retomó foco", "info", "");
}
function preventContextMenu(e) {
  if (isInsideSheet(e)) return; // permitir menú dentro de la hoja
  e.preventDefault();
  raiseAlert("Intento de menú contextual", "info", "Click derecho bloqueado");
}
function onCopyAttempt(e) {
  if (isInsideSheet(e)) return; // permitir copiar dentro de la hoja
  e.preventDefault();
  raiseAlert("Intento de copiar contenido", "warn", "Copy bloqueado");
}
function onPasteAttempt(e) {
  if (isInsideSheet(e)) return; // permitir pegar dentro de la hoja (números/fórmulas)
  e.preventDefault();
  raiseAlert("Intento de pegar contenido", "warn", "Paste bloqueado");
}
function onKeyDown(e) {
  // Allow typing/editing freely inside the spreadsheet modal
  if (isInsideSheet(e)) {
    // Still block DevTools/print even inside sheet
    const k = e.key.toLowerCase();
    if (k === 'f12' || (e.ctrlKey && e.shiftKey && k === 'i') || (e.ctrlKey && k === 'p')) {
      e.preventDefault();
      raiseAlert("Atajo bloqueado dentro de hoja: " + k.toUpperCase(), "warn", "");
    }
    return;
  }
  // Block common shortcuts: Ctrl+C, Ctrl+V, Ctrl+P, Ctrl+S, F12, Ctrl+Shift+I
  const k = e.key.toLowerCase();
  if (e.ctrlKey && ['c', 'v', 'p', 's', 'u'].includes(k)) {
    e.preventDefault();
    raiseAlert("Atajo bloqueado: Ctrl+" + k.toUpperCase(), "warn", "");
  }
  if (k === 'f12' || (e.ctrlKey && e.shiftKey && k === 'i')) {
    e.preventDefault();
    raiseAlert("Intento de abrir DevTools", "warn", "");
  }
}
function resetIdleTimer() {
  if (state.idleTimer) clearTimeout(state.idleTimer);
  state.idleTimer = setTimeout(() => {
    raiseAlert("Inactividad detectada", "info",
      `No hubo actividad por ${state.config.idle} segundos`);
  }, state.config.idle * 1000);
}

function logEvent(event, level, detail) {
  const all = loadStore(STORE_KEYS.alerts, []);
  all.push({ student: state.session.student, event, level, detail, at: Date.now() });
  saveStore(STORE_KEYS.alerts, all);
  if (!state.session.alerts) state.session.alerts = [];
  state.session.alerts.push({ event, level, detail, at: Date.now() });
  saveCurrentSession();
}

function raiseAlert(event, level, detail) {
  if (state.session.finished) return;
  logEvent(event, level, detail);
  state.warnCount++;
  showWarn(event, detail);
  if (state.warnCount >= state.config.maxAlerts) {
    setTimeout(() => submitExam('auto-by-alerts'), 1200);
  }
}

function showWarn(title, msg) {
  document.getElementById('warnTitle').textContent = "⚠️ " + title;
  document.getElementById('warnMessage').textContent = (msg || '') +
    " · Continuar realizando esta acción puede causar el envío automático del examen.";
  document.getElementById('warnCount').textContent = state.warnCount;
  document.getElementById('warnLimit').textContent = state.config.maxAlerts;
  document.getElementById('warnModal').classList.remove('hidden');
}
function dismissWarn() {
  document.getElementById('warnModal').classList.add('hidden');
}

/* =========================================================================
   SUBMIT
   ========================================================================= */
function confirmSubmit() {
  const all = state.bank.sections.flatMap(s => s.questions);
  const answered = all.filter(q => state.session.answers[q.id] !== undefined && state.session.answers[q.id] !== "").length;
  document.getElementById('answeredCount').textContent = `${answered} de ${all.length}`;
  document.getElementById('confirmModal').classList.remove('hidden');
}
function closeConfirm() { document.getElementById('confirmModal').classList.add('hidden'); }

function submitExam(reason) {
  if (state.session.finished) return;
  state.session.finished = true;
  if (state.timerId) clearInterval(state.timerId);
  if (state.autosaveTimer) clearInterval(state.autosaveTimer);
  if (state.idleTimer) clearTimeout(state.idleTimer);
  removeAntiCheat();

  // Auto-grade MC and match
  let scoreMC = 0, maxMC = 0;
  state.bank.sections.forEach(sec => sec.questions.forEach(q => {
    if (q.type === 'mc' || q.type === 'calc') {
      maxMC += q.points;
      if (state.session.answers[q.id] === q.correct) scoreMC += q.points;
    } else if (q.type === 'match') {
      maxMC += q.points;
      const ans = state.session.answers[q.id] || {};
      // Score per pair, partial credit
      const totalPairs = (q.pairs || []).length;
      if (totalPairs > 0) {
        let correct = 0;
        for (const p of q.pairs) {
          if (ans[p.left] === p.right) correct++;
        }
        scoreMC += Math.round(q.points * (correct / totalPairs));
      }
    }
  }));

  const result = {
    student: state.session.student,
    studentCode: state.studentCode || null,
    startedAt: state.session.startedAt,
    finishedAt: Date.now(),
    reason: reason,
    answers: state.session.answers,
    alerts: state.session.alerts || [],
    scoreMC,
    maxMC,
    scoreTotal: scoreMC // open questions pending review
  };
  const all = loadStore(STORE_KEYS.results, []);
  all.push(result);
  saveStore(STORE_KEYS.results, all);

  // Si el alumno tenía permitido un reintento, lo consumimos automáticamente
  if (state.studentCode) {
    const list = loadStore(STORE_KEYS.students, []);
    const s = list.find(st => st.code === state.studentCode);
    if (s && s.allowsRetake) {
      s.allowsRetake = false;
      saveStore(STORE_KEYS.students, list);
    }
  }

  localStorage.removeItem(STORE_KEYS.current);

  closeConfirm();
  document.getElementById('warnModal').classList.add('hidden');
  document.getElementById('finalScore').textContent = `${scoreMC} / ${maxMC} pts (auto-calificado)`;
  document.getElementById('resultModal').classList.remove('hidden');
}

