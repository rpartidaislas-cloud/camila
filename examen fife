/* =========================================================================
   STORAGE helpers
   ========================================================================= */
function loadStore(key, fallback) {
  try { const raw = localStorage.getItem(key); return raw ? JSON.parse(raw) : fallback; }
  catch (e) { return fallback; }
}
function saveStore(key, val) { localStorage.setItem(key, JSON.stringify(val)); }

function init() {
  state.config = loadStore(STORE_KEYS.config, state.config);
  state.bank = loadStore(STORE_KEYS.bank, DEFAULT_BANK);
  // restore in-progress session if exists and not finished
  const sess = loadStore(STORE_KEYS.current, null);
  if (sess && !sess.finished && sess.role) {
    state.user = sess.user;
    state.role = sess.role;
    state.session = sess.session;
    if (state.role === 'admin') showAdmin();
    else resumeStudentSession();
  }
}

