function switchLoginTab(which) {
  document.getElementById('tabStudent').classList.toggle('active', which === 'student');
  document.getElementById('tabAdmin').classList.toggle('active', which === 'admin');
  document.getElementById('studentLogin').classList.toggle('hidden', which !== 'student');
  document.getElementById('adminLogin').classList.toggle('hidden', which !== 'admin');
}

function loginAdmin() {
  const u = document.getElementById('loginUser').value.trim();
  const p = document.getElementById('loginPass').value;
  if (u === "admin" && p === "admin123") {
    state.user = "admin"; state.role = "admin";
    saveStore(STORE_KEYS.current, { role: "admin", user: "admin", session: null });
    showAdmin();
  } else {
    alert("Credenciales inválidas. (Demo: admin / admin123)");
  }
}

function loginStudent() {
  const code = document.getElementById('loginCode').value.trim().toUpperCase();
  if (!code) return alert("Ingresa tu código de alumno");

  const students = loadStore(STORE_KEYS.students, []);
  const student = students.find(s => s.code.toUpperCase() === code);

  if (!student) {
    alert("Código no reconocido. Verifica con tu docente.");
    return;
  }
  // Verificar que no haya tomado el examen ya, salvo que el docente haya autorizado reintento
  const results = loadStore(STORE_KEYS.results, []);
  const taken = results.find(r => r.studentCode === code);
  if (taken && !student.allowsRetake) {
    alert("Este código ya fue usado para tomar el examen el " +
      new Date(taken.finishedAt).toLocaleString() + ".\nPara permitir un reintento, pide al docente que lo autorice.");
    return;
  }

  state.user = student.name;
  state.role = "student";
  state.studentCode = code;
  showWarningScreen();
}

function logout() {
  if (state.timerId) clearInterval(state.timerId);
  if (state.idleTimer) clearTimeout(state.idleTimer);
  if (state.autosaveTimer) clearInterval(state.autosaveTimer);
  state.user = null; state.role = null; state.session = null; state.studentCode = null;
  localStorage.removeItem(STORE_KEYS.current);
  document.getElementById('screenLogin').classList.remove('hidden');
  document.getElementById('screenWarning').classList.add('hidden');
  document.getElementById('screenAdmin').classList.add('hidden');
  document.getElementById('screenStudent').classList.add('hidden');
