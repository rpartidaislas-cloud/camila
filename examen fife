<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sistema de Examen · Fuentes e Instrumentos de Financiamiento</title>
<style>
  :root {
    --bg: #f4f6fa;
    --panel: #ffffff;
    --primary: #1f4e79;
    --primary-soft: #2e75b6;
    --accent: #c00000;
    --ok: #1e7e34;
    --warn: #b8860b;
    --text: #1a1a1a;
    --muted: #5b6470;
    --border: #d8dde6;
    --shadow: 0 4px 18px rgba(31,78,121,0.08);
  }
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; font-family: 'Segoe UI', Roboto, system-ui, Arial, sans-serif; background: var(--bg); color: var(--text); }
  button { font: inherit; cursor: pointer; }
  input, select, textarea { font: inherit; }
  .hidden { display: none !important; }

  /* ===== Top bar ===== */
  .topbar {
    position: sticky; top: 0; z-index: 50;
    display: flex; align-items: center; justify-content: space-between;
    padding: 12px 24px; background: var(--primary); color: white;
    box-shadow: var(--shadow);
  }
  .topbar .brand { font-weight: 700; font-size: 16px; letter-spacing: .3px; }
  .topbar .right { display: flex; align-items: center; gap: 14px; }
  .timer {
    background: rgba(255,255,255,.12);
    padding: 8px 14px; border-radius: 8px; font-weight: 700;
    font-variant-numeric: tabular-nums; letter-spacing: .8px;
    border: 1px solid rgba(255,255,255,.25);
  }
  .timer.warn { background: var(--accent); animation: pulse 1s infinite; }
  @keyframes pulse { 50% { opacity: .55; } }
  .badge {
    background: rgba(255,255,255,.15); padding: 4px 10px; border-radius: 999px;
    font-size: 12px; font-weight: 600;
  }

  /* ===== Layout ===== */
  .container { max-width: 1080px; margin: 24px auto; padding: 0 16px; }
  .card { background: var(--panel); border-radius: 12px; padding: 24px 28px; box-shadow: var(--shadow); margin-bottom: 18px; }
  h1, h2, h3 { color: var(--primary); margin-top: 0; }
  h1 { font-size: 22px; }
  h2 { font-size: 18px; border-bottom: 2px solid var(--primary-soft); padding-bottom: 6px; margin-bottom: 16px; }
  h3 { font-size: 16px; }
  label { display: block; font-weight: 600; margin: 12px 0 6px; }
  input[type=text], input[type=number], input[type=password], textarea, select {
    width: 100%; padding: 10px 12px; border: 1px solid var(--border); border-radius: 8px;
    background: white; outline: none; transition: border .2s;
  }
  input:focus, textarea:focus, select:focus { border-color: var(--primary-soft); }
  textarea { min-height: 110px; resize: vertical; font-family: 'Consolas', 'Courier New', monospace; }

  .btn { display: inline-block; border: none; border-radius: 8px; padding: 10px 18px; font-weight: 600; text-decoration: none; }
  .btn-primary { background: var(--primary); color: white; }
  .btn-primary:hover { background: var(--primary-soft); }
  .btn-ghost { background: transparent; color: var(--primary); border: 1px solid var(--primary); }
  .btn-ghost:hover { background: var(--primary); color: white; }
  .btn-danger { background: var(--accent); color: white; }
  .btn-ok { background: var(--ok); color: white; }
  .btn-sm { padding: 6px 12px; font-size: 13px; }

  /* ===== Progress bar ===== */
  .progress-wrap { background: #e6ebf2; height: 8px; border-radius: 6px; overflow: hidden; margin: 8px 0 16px; }
  .progress-bar { height: 100%; background: linear-gradient(90deg, var(--primary), var(--primary-soft)); transition: width .35s; }

  /* ===== Sections nav ===== */
  .section-nav { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 18px; }
  .section-nav button {
    background: white; border: 1px solid var(--border); padding: 8px 14px; border-radius: 999px;
    color: var(--muted); font-weight: 600; font-size: 13px;
  }
  .section-nav button.active { background: var(--primary); color: white; border-color: var(--primary); }
  .section-nav button.done { border-color: var(--ok); color: var(--ok); }

  /* ===== Question card ===== */
  .question { padding: 18px 0; border-bottom: 1px dashed var(--border); }
  .question:last-child { border-bottom: none; }
  .q-header { font-weight: 600; margin-bottom: 8px; }
  .q-points { color: var(--accent); font-weight: 700; margin-left: 6px; font-size: 13px; }
  .q-text { margin: 0 0 12px; line-height: 1.55; }
  .options { display: flex; flex-direction: column; gap: 8px; }
  .option {
    display: flex; gap: 10px; align-items: flex-start; padding: 10px 12px;
    border: 1px solid var(--border); border-radius: 8px; cursor: pointer;
    transition: background .15s, border-color .15s;
  }
  .option:hover { border-color: var(--primary-soft); background: #f7faff; }
  .option input { margin-top: 3px; }
  .option.selected { border-color: var(--primary); background: #eaf2fb; }

  /* ===== Calculator ===== */
  #calculator {
    position: fixed; bottom: 20px; right: 20px; z-index: 60;
    width: 280px; background: white; border-radius: 14px; box-shadow: 0 12px 40px rgba(0,0,0,.18);
    overflow: hidden; user-select: none;
    transition: transform .25s, opacity .25s;
  }
  #calculator.minimized { transform: translateY(calc(100% - 38px)); }
  .calc-header {
    background: var(--primary); color: white; padding: 8px 12px;
    display: flex; align-items: center; justify-content: space-between;
    cursor: move; font-weight: 700; font-size: 13px;
  }
  .calc-header button { background: transparent; border: none; color: white; font-size: 14px; }
  .calc-display {
    padding: 14px; font-size: 22px; text-align: right; background: #f8fafc;
    font-variant-numeric: tabular-nums; min-height: 56px; word-break: break-all;
    border-bottom: 1px solid var(--border);
  }
  .calc-pad { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: var(--border); }
  .calc-pad button {
    border: none; background: white; padding: 14px 0; font-size: 16px; cursor: pointer;
    transition: background .12s;
  }
  .calc-pad button:hover { background: #eef3f9; }
  .calc-pad .op { background: #f4eee2; color: #8a6d1a; font-weight: 700; }
  .calc-pad .eq { background: var(--primary); color: white; font-weight: 700; }
  .calc-pad .clear { background: #fdecec; color: var(--accent); font-weight: 700; }
  .calc-fab {
    position: fixed; bottom: 20px; right: 20px; z-index: 59;
    width: 54px; height: 54px; border-radius: 50%; background: var(--primary); color: white;
    border: none; box-shadow: 0 10px 26px rgba(31,78,121,.35); font-size: 22px;
  }

  /* ===== Modals ===== */
  .modal-bg {
    position: fixed; inset: 0; background: rgba(20,30,50,.55); display: flex;
    align-items: center; justify-content: center; z-index: 100; padding: 16px;
  }
  .modal {
    background: white; border-radius: 14px; max-width: 460px; width: 100%;
    padding: 28px; box-shadow: 0 20px 60px rgba(0,0,0,.3);
  }
  .modal h2 { margin-top: 0; }
  .modal .icon { font-size: 38px; }

  /* ===== Tables ===== */
  table { width: 100%; border-collapse: collapse; margin: 8px 0 14px; font-size: 14px; }
  th, td { border: 1px solid var(--border); padding: 8px 10px; text-align: left; }
  th { background: var(--primary); color: white; font-weight: 600; }
  tr:nth-child(even) td { background: #fafbfd; }

  .alert-list { max-height: 280px; overflow-y: auto; }
  .alert-row { padding: 10px 12px; border-left: 3px solid var(--accent); background: #fff5f5; margin: 6px 0; border-radius: 0 8px 8px 0; }
  .alert-row.warn { border-left-color: var(--warn); background: #fffaee; }
  .alert-row.info { border-left-color: var(--primary-soft); background: #f0f6fc; }
  .alert-time { color: var(--muted); font-size: 12px; }

  .answer-box { width: 100%; padding: 10px; border: 1px solid var(--border); border-radius: 8px; min-height: 90px; font-family: 'Consolas', monospace; }
  .footer-actions { display: flex; justify-content: space-between; margin-top: 18px; gap: 10px; }
  .save-indicator { color: var(--ok); font-size: 13px; }
  .center { text-align: center; }
  .muted { color: var(--muted); font-size: 13px; }
  .grid-2 { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 14px; }

  /* ===== Spreadsheet (lateral panel, no longer covers the question) ===== */
  #sheetFab {
    position: fixed; bottom: 84px; right: 20px; z-index: 59;
    height: 54px; padding: 0 18px; border-radius: 27px; background: #1e7e34; color: white;
    border: none; box-shadow: 0 10px 26px rgba(30,126,52,.35); font-size: 14px; font-weight: 700;
    display: flex; align-items: center; gap: 8px;
  }
  #sheetFab .ic { font-size: 20px; }
  /* Side panel: docks to the right side. The question stays visible on the left. */
  .sheet-modal {
    position: fixed; top: 64px; right: 0; bottom: 0;
    width: min(58%, 780px);
    z-index: 60;
    background: transparent;
    padding: 10px 10px 10px 0;
    pointer-events: none;  /* clicks pass through outside .sheet-window */
  }
  .sheet-modal:not(.hidden) .sheet-window { pointer-events: auto; }
  .sheet-window {
    background: white; border-radius: 14px; width: 100%; height: 100%;
    display: flex; flex-direction: column;
    box-shadow: -10px 4px 32px rgba(0,0,0,.18);
    overflow: hidden;
    border: 1px solid var(--border);
  }
  /* When sheet is open, shrink the main container so question stays visible */
  body.sheet-open .container { padding-right: calc(min(58%, 780px) + 16px); transition: padding .25s; }
  body.sheet-open .topbar { padding-right: 24px; }
  /* On narrow screens, fall back to bottom-docked panel */
  @media (max-width: 900px) {
    .sheet-modal { width: 100%; top: auto; right: 0; left: 0; bottom: 0; height: 60vh; padding: 0; }
    body.sheet-open .container { padding-right: 16px; padding-bottom: calc(60vh + 16px); }
  }
  .sheet-header {
    background: #1e7e34; color: white; padding: 10px 16px;
    display: flex; align-items: center; justify-content: space-between;
  }
  .sheet-header .left { display: flex; align-items: center; gap: 10px; font-weight: 700; }
  .sheet-header button { background: transparent; color: white; border: 1px solid rgba(255,255,255,.5); padding: 6px 12px; border-radius: 6px; }
  .sheet-toolbar {
    background: #f4f6fa; padding: 8px 12px; display: flex; align-items: center; gap: 10px;
    border-bottom: 1px solid var(--border); font-size: 13px;
  }
  .sheet-toolbar .name-box {
    background: white; border: 1px solid var(--border); padding: 4px 10px; border-radius: 6px;
    font-weight: 700; min-width: 56px; text-align: center; color: var(--primary);
  }
  .sheet-toolbar .formula-bar {
    flex: 1; padding: 6px 12px; border: 1px solid var(--border); border-radius: 6px;
    font-family: 'Consolas', 'Courier New', monospace; outline: none; background: white;
  }
  .sheet-toolbar .formula-bar:focus { border-color: var(--ok); }
  .sheet-grid-wrap { flex: 1; overflow: auto; background: #fafbfd; position: relative; }
  .sheet-grid { border-collapse: collapse; font-size: 13px; }
  .sheet-grid th, .sheet-grid td {
    border: 1px solid #c8cfdb; padding: 0; min-width: 92px; height: 26px;
    background: white;
  }
  .sheet-grid thead th, .sheet-grid tbody th {
    background: #eef3f9; color: #4a5666; font-weight: 700; text-align: center;
    min-width: 36px; padding: 4px 6px; position: sticky;
  }
  .sheet-grid thead th { top: 0; z-index: 2; }
  .sheet-grid tbody th { left: 0; z-index: 1; }
  .sheet-grid thead th.corner { left: 0; z-index: 3; }
  .sheet-cell {
    width: 100%; height: 100%; min-height: 26px; padding: 4px 8px; border: none; outline: none;
    background: transparent; font-size: 13px; font-family: inherit;
    text-align: right; font-variant-numeric: tabular-nums;
    cursor: cell;
  }
  .sheet-cell.text { text-align: left; }
  .sheet-cell.error { color: var(--accent); }
  .sheet-cell.editing { background: #fff8d6; text-align: left; font-family: 'Consolas', monospace; cursor: text; }
  .sheet-cell.selected-display { background: #eaf2fb; box-shadow: inset 0 0 0 2px var(--primary); }
  .sheet-cell.range-selected { background: rgba(46,117,182,.15); }
  .sheet-cell.fill-target { background: rgba(31,126,52,.12); border: 1px dashed #1e7e34 !important; }

  /* Fill handle (manija de relleno como Excel) */
  .sheet-fill-handle {
    position: absolute; width: 9px; height: 9px;
    background: var(--primary); border: 1px solid white;
    cursor: crosshair; z-index: 10; display: none;
    box-shadow: 0 0 0 1px var(--primary);
  }
  .sheet-fill-handle:hover { background: #c00000; box-shadow: 0 0 0 1px #c00000; }
  .sheet-help {
    background: #fff8e1; padding: 8px 12px; border-top: 1px solid #f0e2a8;
    font-size: 12px; color: #6b5d1f;
  }
  .sheet-help b { color: #4d4310; }

  /* ===== Sheet toolbar (operators + functions) ===== */
  .sheet-tools {
    display: flex; flex-wrap: wrap; align-items: center; gap: 6px; padding: 8px 12px;
    background: #f8fafc; border-bottom: 1px solid var(--border);
  }
  .tool-label {
    font-size: 11px; font-weight: 700; color: var(--muted);
    text-transform: uppercase; letter-spacing: .5px; margin-right: 4px;
  }
  .tool-group { display: inline-flex; gap: 3px; }
  .tool-sep { width: 1px; height: 24px; background: #c8cfdb; margin: 0 6px; }
  .op-btn, .fn-btn {
    border: 1px solid #c8cfdb; background: white; padding: 6px 12px;
    border-radius: 6px; font-size: 14px; font-weight: 700; cursor: pointer;
    min-width: 38px; transition: background .12s, border-color .12s, transform .08s;
    line-height: 1; user-select: none;
  }
  .op-btn { color: var(--primary); font-family: 'Consolas', monospace; font-size: 16px; }
  .fn-btn { color: var(--ok); font-size: 12px; min-width: 50px; }
  .op-btn:hover, .fn-btn:hover { background: #eef3f9; border-color: var(--primary-soft); }
  .op-btn:active, .fn-btn:active { background: #d8e4f0; transform: scale(0.95); }
  .op-btn.eq { background: #fff8e1; color: #b8860b; border-color: #f0e2a8; }
  .op-btn.eq:hover { background: #fef0c2; }
  /* Format buttons */
  .fmt-btn {
    border: 1px solid #c8cfdb; background: white; padding: 6px 10px;
    border-radius: 6px; font-size: 12px; font-weight: 700; cursor: pointer;
    transition: background .12s, border-color .12s, transform .08s;
    line-height: 1; user-select: none; min-width: 50px;
  }
  .fmt-btn:hover { background: #eef3f9; border-color: var(--primary-soft); }
  .fmt-btn:active { transform: scale(0.95); }
  .fmt-btn.active { background: var(--primary); color: white; border-color: var(--primary); }
  .fmt-btn.currency { color: #1e7e34; }
  .fmt-btn.currency.active { background: #1e7e34; color: white; border-color: #1e7e34; }
  .fmt-btn.percent { color: #b8860b; }
  .fmt-btn.percent.active { background: #b8860b; color: white; border-color: #b8860b; }
  /* Cells with format */
  .sheet-cell.fmt-currency { color: #1e7e34; font-weight: 600; }
  .sheet-cell.fmt-percent { color: #b8860b; font-weight: 600; }
  /* Indicador de fórmula viva (esquinita verde) */
  .sheet-grid td { position: relative; }
  .sheet-cell.has-formula::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 0;
    height: 0;
    border-style: solid;
    border-width: 6px 6px 0 0;
    border-color: #1e7e34 transparent transparent transparent;
    pointer-events: none;
  }
  /* Estilo del indicador "fx" en la barra de fórmulas */
  .formula-prefix {
    background: #1e7e34; color: white; padding: 4px 8px; border-radius: 4px;
    font-style: italic; font-weight: 700; font-size: 12px; margin-right: 6px;
  }

  /* ===== Login tabs ===== */
  .login-tab {
    background: transparent; border: none; padding: 10px 18px;
    font-weight: 700; color: var(--muted); cursor: pointer; border-bottom: 3px solid transparent;
    margin-bottom: -1px; font-size: 14px;
  }
  .login-tab.active { color: var(--primary); border-bottom-color: var(--primary); }

  /* ===== Admin students table ===== */
  .student-row { display: flex; gap: 8px; align-items: center; padding: 6px 0; border-bottom: 1px dashed #e6ebf2; }
  .student-row .name { flex: 1; }
  .student-row .code { font-family: 'Consolas', monospace; background: #fff8e1; padding: 4px 10px; border-radius: 4px; font-weight: 700; color: #8a6d1a; }
  .student-row.taken .code { background: #e2efda; color: #385723; }

  /* ===== Visual question editor ===== */
  .qe-section {
    border: 1px solid var(--border); border-radius: 8px; padding: 14px; margin-bottom: 12px; background: #fafbfd;
  }
  .qe-section h3 {
    margin: 0 0 10px; padding-bottom: 8px; border-bottom: 2px solid var(--primary-soft);
    display: flex; gap: 10px; align-items: center; flex-wrap: wrap;
  }
  .qe-section h3 input { flex: 1; min-width: 200px; max-width: 380px; font-weight: 700; font-size: 15px; }
  .qe-question {
    background: white; border: 1px solid var(--border); border-radius: 8px; padding: 12px; margin: 10px 0;
  }
  .qe-question .qe-meta { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; margin-bottom: 8px; font-size: 13px; }
  .qe-question .qe-meta input, .qe-question .qe-meta select { padding: 4px 8px; font-size: 13px; }
  .qe-question .qe-meta .pts-input { width: 80px; }
  .qe-question .qe-meta .points-tag { background: var(--primary); color: white; padding: 2px 10px; border-radius: 999px; font-weight: 700; font-size: 12px; }
  .qe-options { display: flex; flex-direction: column; gap: 6px; margin: 8px 0; }
  .qe-option { display: flex; gap: 6px; align-items: center; }
  .qe-option input[type=text] { flex: 1; }
  .qe-option .correct-radio { transform: scale(1.2); margin: 0 6px; }
  .qe-actions { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 8px; }

  /* ===== Match (drag-and-drop) question ===== */
  .match-wrapper { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin: 12px 0; }
  .match-col { background: #fafbfd; border: 1px solid var(--border); border-radius: 8px; padding: 12px; }
  .match-col h4 { margin: 0 0 10px; color: var(--primary); font-size: 14px; }
  .match-item {
    background: white; border: 2px solid var(--border); border-radius: 8px; padding: 10px 12px;
    margin-bottom: 8px; display: flex; gap: 10px; align-items: center; min-height: 44px;
    transition: background .15s, border-color .15s;
  }
  .match-item .label { flex: 1; font-weight: 600; }
  .match-item .slot {
    flex: 1; min-height: 30px; border: 2px dashed #c8cfdb; border-radius: 6px;
    padding: 6px 10px; background: #f4f6fa; color: var(--muted); font-size: 13px;
    display: flex; align-items: center; gap: 6px;
  }
  .match-item .slot.dragover { background: #fff8e1; border-color: #f0c000; color: #8a6d1a; }
  .match-item .slot .placed { color: var(--text); font-weight: 600; flex: 1; }
  .match-item .slot .placed-remove {
    background: var(--accent); color: white; border: none; border-radius: 50%;
    width: 22px; height: 22px; cursor: pointer; font-size: 12px; line-height: 1;
  }
  .match-pool .draggable {
    background: #eaf2fb; border: 2px solid var(--primary-soft); cursor: grab;
    padding: 10px 12px; border-radius: 8px; margin-bottom: 6px; font-weight: 600;
    user-select: none;
  }
  .match-pool .draggable:active { cursor: grabbing; }
  .match-pool .draggable.dragging { opacity: .5; }
  .match-pool .draggable.placed { display: none; }

  /* ===== File input button styling ===== */
  .file-input-wrap { position: relative; display: inline-block; }
  .file-input-wrap input[type=file] {
    position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%;
  }
</style>
</head>
<body>

<!-- ================= LOGIN ================= -->
<div id="screenLogin" class="container">
  <div class="card" style="max-width: 480px; margin: 60px auto;">
    <h1 class="center">Sistema de Examen</h1>
    <p class="muted center">Fuentes e Instrumentos de Financiamiento para las Empresas</p>

    <!-- Tabs -->
    <div style="display:flex;gap:8px;margin:16px 0;border-bottom:1px solid var(--border)">
      <button id="tabStudent" class="login-tab active" onclick="switchLoginTab('student')">👨‍🎓 Soy alumno</button>
      <button id="tabAdmin" class="login-tab" onclick="switchLoginTab('admin')">⚙️ Soy administrador</button>
    </div>

    <!-- Student form: just code -->
    <div id="studentLogin">
      <label>Código de alumno</label>
      <input id="loginCode" type="text" placeholder="Ej. ABC123" autocomplete="off" onkeydown="if(event.key==='Enter')loginStudent()">
      <p class="muted" style="margin-top:8px">Pide tu código al docente. No necesitas contraseña.</p>
      <div style="text-align:right;margin-top:14px">
        <button class="btn btn-primary" onclick="loginStudent()">Ingresar al examen</button>
      </div>
    </div>

    <!-- Admin form: user + password -->
    <div id="adminLogin" class="hidden">
      <label>Usuario</label>
      <input id="loginUser" type="text" placeholder="admin" autocomplete="off">
      <label>Contraseña</label>
      <input id="loginPass" type="password" placeholder="contraseña" onkeydown="if(event.key==='Enter')loginAdmin()">
      <p class="muted" style="margin-top:8px">Demo: <b>admin</b> / <b>admin123</b></p>
      <div style="text-align:right;margin-top:14px">
        <button class="btn btn-primary" onclick="loginAdmin()">Ingresar al panel</button>
      </div>
    </div>
  </div>
</div>

<!-- ================= PRE-EXAM WARNING ================= -->
<div id="screenWarning" class="hidden container">
  <div class="card" style="max-width: 720px; margin: 40px auto;">
    <div style="text-align:center;font-size:48px">⚠️</div>
    <h1 class="center">Antes de iniciar tu examen</h1>
    <p class="muted center" id="warnStudentName"></p>

    <div style="background:#fff8e1;border-left:4px solid #f0e2a8;padding:16px 20px;border-radius:8px;margin:18px 0">
