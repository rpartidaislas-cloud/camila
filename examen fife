  const reader = new FileReader();
  reader.onload = e => {
    try {
      const parsed = JSON.parse(e.target.result);
      if (!parsed.sections || !Array.isArray(parsed.sections)) throw new Error("Falta el array sections[]");
      state.bank = parsed;
      saveStore(STORE_KEYS.bank, parsed);
      renderBankVisual();
      alert(`✓ Examen importado: ${parsed.sections.length} secciones, ${parsed.sections.reduce((a,s)=>a+s.questions.length,0)} preguntas.`);
    } catch (err) {
      alert("❌ Error al importar: " + err.message);
