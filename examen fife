        ${(q.pairs || []).map((p, pi) => `
          <div style="margin-top:6px">
            <input type="text" value="${escapeHTML(p.right || '')}" placeholder="Match para ${escapeHTML(p.left || '...')}" onchange="editMatchRight(${si},${qi},${pi},this.value)">
          </div>`).join('')}
      </div>
    </div>
    <button class="btn btn-sm btn-ghost" onclick="addMatchPair(${si},${qi})" style="margin-top:8px">➕ Agregar par</button>`;
    return h;
  } else if (q.type === 'open') {
    return `<p class="muted" style="font-size:12px;margin:6px 0">Las preguntas abiertas se califican manualmente. El alumno verá un cuadro de respuesta amplio.</p>
    <label style="font-size:12px">Rúbrica (opcional · JSON):</label>
    <textarea style="min-height:60px;width:100%;font-family:monospace;font-size:12px" onchange="editQuestionRubric(${si},${qi},this.value)" placeholder='[{"criterio":"...","pts":5}]'>${escapeHTML(JSON.stringify(q.rubric || [], null, 2))}</textarea>`;
  }
  return '';
}

